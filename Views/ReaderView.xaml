<UserControl x:Class="Ebook_Reader.Views.ReaderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:Ebook_Reader.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <converters:MathAddConverter x:Key="MathAddConverter"/>
    </UserControl.Resources>
    <Grid Background="{StaticResource SidebarBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Reader Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBackgroundBrush}" BorderBrush="{StaticResource MutedTextBrush}" BorderThickness="0,0,0,0.5">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Command="{Binding GoBackCommand}" 
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="{StaticResource DeepTextBrush}"
                        Padding="0" HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ArrowLeft" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Back to Library" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentBook.Title}" 
                               FontWeight="Bold" Foreground="{StaticResource DeepTextBrush}"
                               FontSize="16" TextTrimming="CharacterEllipsis" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2,0,0">
                        <TextBlock Text="Symbols: " FontSize="10" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock Text="{Binding TextLength}" FontSize="10" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,10,0"/>
                        <TextBlock Text="Preview: " FontSize="10" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock Text="{Binding ContentPreview}" FontSize="10" Foreground="{StaticResource MutedTextBrush}" MaxWidth="200" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <!-- Theme Selector -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                        <Button Style="{StaticResource MaterialDesignFlatButton}" Padding="4" 
                                Command="{Binding ChangeThemeCommand}" CommandParameter="Default"
                                ToolTip="Default Book Theme">
                            <Border Width="20" Height="20" Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="10">
                                <TextBlock Text="D" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#333"/>
                            </Border>
                        </Button>
                        <Button Style="{StaticResource MaterialDesignFlatButton}" Padding="4"
                                Command="{Binding ChangeThemeCommand}" CommandParameter="Paper"
                                ToolTip="Paper/Sepia Theme">
                            <Border Width="20" Height="20" Background="#F4ECD8" CornerRadius="10">
                                <TextBlock Text="P" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#3C3C3C"/>
                            </Border>
                        </Button>
                        <Button Style="{StaticResource MaterialDesignFlatButton}" Padding="4"
                                Command="{Binding ChangeThemeCommand}" CommandParameter="Night"
                                ToolTip="Night Theme">
                            <Border Width="20" Height="20" Background="#1A1A1A" CornerRadius="10">
                                <TextBlock Text="N" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#EEE"/>
                            </Border>
                        </Button>
                    </StackPanel>
                    
                    <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="{StaticResource MutedTextBrush}">
                        <materialDesign:PackIcon Kind="BookmarkPlusOutline" Width="20" Height="20"/>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="{StaticResource MutedTextBrush}">
                        <materialDesign:PackIcon Kind="SettingsOutline" Width="20" Height="20"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content (WebView) -->
        <Grid Grid.Row="1">
            <wv2:WebView2 x:Name="webView" />
            
            <!-- Navigation Overlay -->
            <Border VerticalAlignment="Bottom" HorizontalAlignment="Center" 
                    Margin="0,0,0,30" Background="White" CornerRadius="25" Padding="10,5">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource MaterialDesignFlatButton}" 
                            Command="{Binding PreviousCommand}"
                            Width="40" Height="40" Padding="0"
                            materialDesign:ButtonAssist.CornerRadius="20">
                        <materialDesign:PackIcon Kind="ChevronLeft" Width="24" Height="24"/>
                    </Button>
                    
                    <StackPanel VerticalAlignment="Center" Margin="15,0" Orientation="Horizontal">
                        <TextBlock Text="{Binding CurrentPosition, Converter={StaticResource MathAddConverter}, ConverterParameter=1}" 
                                   FontWeight="Bold" Foreground="{StaticResource AccentCoralBrush}"/>
                        <TextBlock Text=" / " Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBlock Text="{Binding TotalPositions}" Foreground="{StaticResource MutedTextBrush}"/>
                    </StackPanel>
                    
                    <Button Style="{StaticResource MaterialDesignFlatButton}" 
                            Command="{Binding NextCommand}"
                            Width="40" Height="40" Padding="0"
                            materialDesign:ButtonAssist.CornerRadius="20">
                        <materialDesign:PackIcon Kind="ChevronRight" Width="24" Height="24"/>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
