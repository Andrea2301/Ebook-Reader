<Window x:Class="Ebook_Reader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:m="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:Ebook_Reader"
        xmlns:vm="clr-namespace:Ebook_Reader.ViewModels"
        xmlns:views="clr-namespace:Ebook_Reader.Views"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="My Ebook Reader" Height="550" Width="1090">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:LibraryViewModel}">
            <views:LibraryView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BooksViewModel}">
            <views:BooksView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReaderViewModel}">
            <views:ReaderView />
        </DataTemplate>
    </Window.Resources>

    <Grid Background="{StaticResource PrimaryBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="70"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Vertical Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBackgroundBrush}" CornerRadius="0,20,20,0">
            <Border.Effect>
                <StaticResource ResourceKey="SoftShadow"/>
            </Border.Effect>
            <Grid>
                <StackPanel VerticalAlignment="Top" Margin="0,30,0,0">
                    <materialDesign:PackIcon Kind="Pencil" Width="30" Height="30" Foreground="{StaticResource DeepTextBrush}" HorizontalAlignment="Center" Margin="0,0,0,40"/>
                    
                    <Button Style="{StaticResource MaterialDesignFlatButton}" Margin="0,10" Foreground="{StaticResource AccentCoralBrush}"
                            Command="{Binding NavigateToLibraryCommand}">
                        <materialDesign:PackIcon Kind="Home" Width="24" Height="24"/>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignFlatButton}" Margin="0,10" Foreground="{StaticResource MutedTextBrush}"
                            Command="{Binding NavigateToBooksCommand}">
                        <materialDesign:PackIcon Kind="BookOpen" Width="24" Height="24"/>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignFlatButton}" Margin="0,10" Foreground="{StaticResource MutedTextBrush}">
                        <materialDesign:PackIcon Kind="Timer" Width="24" Height="24"/>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignFlatButton}" Margin="0,10" Foreground="{StaticResource MutedTextBrush}">
                        <materialDesign:PackIcon Kind="Bookmark" Width="24" Height="24"/>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignFlatButton}" Margin="0,10" Foreground="{StaticResource MutedTextBrush}"
                            Command="{Binding LibraryVM.AddBookCommand}">
                        <materialDesign:PackIcon Kind="Plus" Width="24" Height="24"/>
                    </Button>
                </StackPanel>
                
                <Button Style="{StaticResource MaterialDesignFlatButton}" VerticalAlignment="Bottom" Margin="0,0,0,30" Foreground="{StaticResource MutedTextBrush}">
                    <materialDesign:PackIcon Kind="Settings" Width="24" Height="24"/>
                </Button>
            </Grid>
        </Border>

        <!-- Main Workspace -->
        <Grid Grid.Column="1" Margin="40,30,40,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Content -->
            </Grid.RowDefinitions>

            <!-- Top Header -->
            <Grid Grid.Row="0" Margin="0,0,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Search" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox materialDesign:HintAssist.Hint="Search book name, author..." 
                             BorderThickness="0" Background="Transparent" Width="250" VerticalAlignment="Center"
                             Foreground="{StaticResource DeepTextBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="Bell" Foreground="{StaticResource DeepTextBrush}" Margin="20,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Camilo V." FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,15,0" Foreground="{StaticResource DeepTextBrush}"/>
                    <Ellipse Width="35" Height="35">
                        <Ellipse.Fill>
                            <ImageBrush ImageSource="https://ui-avatars.com/api/?name=Camilo+V&amp;background=random" />
                        </Ellipse.Fill>
                    </Ellipse>
                </StackPanel>
            </Grid>

            <!-- Dynamic View Content -->
            <ContentControl Grid.Row="1" Content="{Binding CurrentView}" />
        </Grid>
    </Grid>
</Window>
